# ============================================================
# MCP RAG Knowledge Base — Environment Variables
# ============================================================
# Copy this file to .env (in the same directory) and uncomment
# / adjust the values you want to override:
#
#   cp .env.example .env
#   # edit .env -> uncomment, replace placeholders, set secrets
# ============================================================

# ----------------------------------------------------------
# General
# ----------------------------------------------------------

# Logging verbosity (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# RAG_LOG_LEVEL=INFO

# ----------------------------------------------------------
# LLM -- Completions (text generation)
# ----------------------------------------------------------

# Ollama (legacy / local fallback). Kept for backward compatibility.
# Model name for answer generation via Ollama (e.g. "qwen2.5:3b")
# RAG_OLLAMA_MODEL=qwen2.5:3b

# Sampling temperature for Ollama completions (0.0 = deterministic)
# RAG_OLLAMA_TEMPERATURE=0.0

# OpenAI-compatible API for completions. When any of these three are set,
# the server uses them *instead* of Ollama for answer generation.

# Base URL for the OpenAI-compatible completions API
# (e.g. "http://localhost:11434/v1" for Ollama, or an OpenAPI endpoint)
# RAG_OPENAI_COMPLETIONS_BASE_URL=

# Model name to use for completions (e.g. "gpt-4o", "llama-3")
# RAG_OPENAI_COMPLETIONS_MODEL=

# API key for authenticating with the completions provider
# RAG_OPENAI_COMPLETIONS_API_KEY=

# ----------------------------------------------------------
# Embeddings
# ----------------------------------------------------------

# OpenAI-compatible API for text embeddings. When any of these three are
# set the indexer and retriever use them instead of ChromaDB's default
# embeddings. If left blank the project falls back to ChromaDB defaults.

# Base URL for the OpenAI-compatible embeddings API
# (e.g. "http://localhost:11434/v1" for Ollama)
# RAG_OPENAI_EMBEDDINGS_BASE_URL=

# Embedding model name (e.g. "text-embedding-3-small", "nomic-embed")
# RAG_OPENAI_EMBEDDINGS_MODEL=

# API key for authenticating with the embeddings provider
# RAG_OPENAI_EMBEDDINGS_API_KEY=

# ----------------------------------------------------------
# ChromaDB
# ----------------------------------------------------------

# Directory where ChromaDB persists its data store
# RAG_CHROMA_PERSIST_DIR=./chroma_db

# Name of the ChromaDB collection used for storing document vectors
# RAG_CHROMA_COLLECTION=rag_knowledge_base

# Distance metric for the HNSW index ("cosine", "l2", or "ip")
# RAG_CHROMA_HNSW_SPACE=cosine

# ----------------------------------------------------------
# Document processing / chunking
# ----------------------------------------------------------

# File extensions that the indexer will process (comma-separated list)
# Supported: .md, .txt, .py, .js, .ts, .json, .yaml
# RAG_SUPPORTED_EXTENSIONS=.md,.txt,.py,.js,.ts,.json,.yaml

# Chunk size in tokens for splitting documents
# RAG_CHUNK_SIZE=500

# Number of tokens to overlap between adjacent chunks
# RAG_CHUNK_OVERLAP=50

# Per-extension overrides: JSON dict mapping extension -> {chunk_size, chunk_overlap}
# Example: '{".py": {"chunk_size": 800, "chunk_overlap": 50}}'
# RAG_CHUNK_CONFIGS={}

# ----------------------------------------------------------
# Retrieval & ranking
# ----------------------------------------------------------

# K parameter for Reciprocal Rank Fusion (RRF) hybrid re-ranking
# Higher values give more weight to rank position; typical range 40-80
# RAG_RRF_K=60

# Number of chunks returned by the hybrid retriever (BM25 + vector -> RRF)
# RAG_RETRIEVE_TOP_K=10

# Default number of documents returned by the find_relevant_docs tool
# RAG_FIND_RELEVANT_DOCS_DEFAULT_TOP_K=5

# Vector search oversample factor: actual n_results = top_k x oversample
# Used to compensate for irrelevant chunks filtered out later in the pipeline
# RAG_VECTOR_OVERSAMPLE_FACTOR=3

# ----------------------------------------------------------
# Corrective RAG / LangGraph
# ----------------------------------------------------------

# Minimum number of relevant chunks required before generating a final answer
# If fewer than this many pass relevance grading, the query is broadened
# RAG_MIN_RELEVANT_CHUNKS=3

# Maximum number of broaden-and-retry loops allowed when chunks are not
# relevant enough. Prevents infinite loops on unanswerable queries.
# RAG_MAX_BROADEN_LOOPS=2
