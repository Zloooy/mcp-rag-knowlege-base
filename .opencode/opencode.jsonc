{
    "$schema": "https://opencode.ai/config.json",
    "instructions": [
        "**/AGENTS.md"
    ],
    "lsp": true,
    "formatter": {
        "ruff": {
            "disabled": true
        },
        "black": {
            "command": ["black", "$FILE"],
            "extensions": [".py"]
        },
    },
    "mcp": {
        "deepwiki": {
            "enabled": true
        }
    },
    "permission": {
        "external_directory": "deny",
        "read": {
            "*": "allow",
            "session*.md": "deny",
            ".opencode/*": "deny",
        }
    },
}